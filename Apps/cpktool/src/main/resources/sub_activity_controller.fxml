<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="650.0" styleClass="thebackground" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hp.jetadvantage.link.pkgmgt.hpkutil.activities.SubActivity">
   <children>
      <VBox prefWidth="650.0">
         <children>
            <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
               <children>
                  <Label prefHeight="24.0" prefWidth="130.0" text="%menu_uuid" />
                  <TextField fx:id="textUuid" promptText="%sub_activity_uuid" HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleUuidGenerateButtonAction" prefWidth="120.0" text="%btn_generate" />
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </HBox>

             <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                 <children>
                     <Label prefHeight="24.0" prefWidth="130.0" text="%platform_id" />
                     <TextField fx:id="textPlatformId" promptText="%hint_platform_path" HBox.hgrow="ALWAYS" />
                 </children>
                 <VBox.margin>
                     <Insets />
                 </VBox.margin>
                 <padding>
                     <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                 </padding>
             </HBox>

             <HBox layoutX="20.0" layoutY="20.0" spacing="20.0">
                 <children>
                     <Button fx:id="btnAddSubActivity" mnemonicParsing="false" onAction="#handleAddSubActivity" prefWidth="100.0" text="%btn_add" />
                     <Button fx:id="btnDelete" disable="true" mnemonicParsing="false" onAction="#handleDeleteSubActivity" prefWidth="100.0" styleClass="buttonRed" text="%btn_delete" />
                     <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel" prefWidth="100.0" styleClass="buttonWhite" text="%btn_cancel" />
                 </children>
                 <padding>
                     <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                 </padding>
             </HBox>
         </children>
      </VBox>
   </children>
    <stylesheets>
        <URL value="@sample.css" />
    </stylesheets>
</VBox>
