<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>
<VBox prefWidth="650.0" styleClass="thebackground" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hp.jetadvantage.link.pkgmgt.hpkutil.activities.SettingsActivity">
    <children>
        <VBox>
            <children>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <Label prefHeight="24.0" text="%menu_version_change" styleClass="sectionTitle"/>
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="0.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <Label prefHeight="24.0" text="%msg_version_change" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="20.0" right="10.0" top="5.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <CheckBox fx:id="checkVersion_1_0" mnemonicParsing="false" prefHeight="25.0" text="%hpk_version_1_0" onAction="#handleVersion_1_0_Checked" />
                        <Label prefHeight="24.0" text="%explain_hpk_1_0" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="0.0" left="20.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <CheckBox fx:id="checkVersion_1_1" mnemonicParsing="false" prefHeight="25.0" text="%hpk_version_1_1" onAction="#handleVersion_1_1_Checked" />
                        <Label prefHeight="24.0" text="%explain_hpk_1_1" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="0.0" left="20.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <CheckBox fx:id="checkVersion_1_2" mnemonicParsing="false" prefHeight="25.0" text="%hpk_version_1_2" onAction="#handleVersion_1_2_Checked" />
                        <Label prefHeight="24.0" text="%explain_hpk_1_2" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="0.0" left="20.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <CheckBox fx:id="checkVersion_1_3" mnemonicParsing="false" prefHeight="25.0" text="%hpk_version_1_3" onAction="#handleVersion_1_3_Checked" />
                        <Label prefHeight="24.0" text="%explain_hpk_1_3" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="0.0" left="20.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <CheckBox fx:id="checkVersion_1_4" mnemonicParsing="false" prefHeight="25.0" text="%hpk_version_1_4" onAction="#handleVersion_1_4_Checked" />
                        <Label prefHeight="24.0" text="%explain_hpk_1_4" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="0.0" left="20.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="20.0">
                    <children>
                        <Button fx:id="btnApply" mnemonicParsing="false" onAction="#handleApply" prefWidth="100.0" text="%btn_apply" />
                        <Label fx:id="textApplyMsg" prefHeight="24.0" />
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </children>
    <stylesheets>
        <URL value="@sample.css" />
    </stylesheets>
</VBox>
