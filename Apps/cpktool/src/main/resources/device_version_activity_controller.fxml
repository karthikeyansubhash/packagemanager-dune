<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressBar?>
<VBox prefWidth="650.0" styleClass="thebackground" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hp.jetadvantage.link.pkgmgt.hpkutil.activities.ProviderForDeviceVersionActivity">
   <children>
      <VBox prefWidth="650.0">
         <children>
            <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
               <children>
                   <Label prefHeight="24.0" prefWidth="130.0" text="%menu_host" />
                   <TextField fx:id="textHost" promptText="%menu_host" HBox.hgrow="ALWAYS" />
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </HBox>

             <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                 <children>
                     <Label prefHeight="24.0" prefWidth="130.0" text="%menu_admin_password" />
                     <PasswordField fx:id="textAdminPassword" promptText="%menu_admin_password" HBox.hgrow="ALWAYS" />
                 </children>
                 <VBox.margin>
                     <Insets />
                 </VBox.margin>
                 <padding>
                     <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                 </padding>
             </HBox>

             <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                 <children>
                     <Label prefHeight="24.0" prefWidth="130.0" />
                     <Label fx:id="textStatus" prefHeight="24.0" textFill="#8c5123" HBox.hgrow="ALWAYS" />
                 </children>
                 <VBox.margin>
                     <Insets />
                 </VBox.margin>
                 <padding>
                     <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                 </padding>
             </HBox>

             <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                 <children>
                     <Button fx:id="btnOK" mnemonicParsing="false" onAction="#handleGetVersion" prefWidth="100.0" text="%btn_ok" />
                     <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel" prefWidth="100.0" styleClass="buttonWhite" text="%btn_cancel" />
                     <ProgressBar fx:id="progressBar" prefHeight="26.0" prefWidth="381.0" progress="-1.0" visible="false" HBox.hgrow="ALWAYS" />
                 </children>
                 <VBox.margin>
                     <Insets />
                 </VBox.margin>
                 <padding>
                     <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                 </padding>
             </HBox>
         </children>
      </VBox>
   </children>
    <stylesheets>
        <URL value="@sample.css" />
    </stylesheets>
</VBox>
