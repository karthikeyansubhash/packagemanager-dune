<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>
<VBox prefWidth="650.0" xmlns:fx="http://javafx.com/fxml" fx:controller="com.hp.jetadvantage.link.pkgmgt.hpkutil.activities.MainActivityForWeb"
      styleClass="thebackground">
    <children>
        <VBox>

            <children>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <Label fx:id="textDescription" text=""/>
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0" visible="false" managed="false">
                    <children>
                        <Label prefHeight="24.0" prefWidth="170.0" text="%menu_install_file" />
                        <TextField fx:id="textInstallFile" editable="false" HBox.hgrow="ALWAYS"  />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <Label prefHeight="24.0" prefWidth="170.0" text="%menu_uuid" />
                        <TextField fx:id="textUuid" promptText="%hint_uuid" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleUuidGenerateButtonAction" prefWidth="100.0" text="%btn_generate" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <Label prefHeight="24.0" prefWidth="170.0" text="%menu_name" />
                        <TextField fx:id="textName" promptText="%hint_app_name" HBox.hgrow="ALWAYS" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <Label prefHeight="24.0" prefWidth="170.0" text="%menu_vendor_name" />
                        <TextField fx:id="textVendor" promptText="%menu_vendor_name" HBox.hgrow="ALWAYS" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
                <HBox layoutX="20.0" layoutY="20.0" spacing="10.0">
                    <children>
                        <Label prefHeight="24.0" prefWidth="170.0" text="%menu_date" />
                        <TextField fx:id="dateCreation" maxWidth="1.7976931348623157E308" promptText="%menu_date" HBox.hgrow="ALWAYS" />
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>

                <fx:include fx:id="buttonManager" source="button_manager_activity.fxml" />

                <HBox layoutX="20.0" layoutY="20.0" spacing="20.0">
                    <children>
                        <Button fx:id="btnCreateHpk" onAction="#handleCreateHpkMenuAction" mnemonicParsing="false" prefWidth="100.0" text="%btn_create_hpk"/>
                        <Label fx:id="textWarningMsg" text="" textFill="#8c5123"/>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </children>

    <stylesheets>
        <URL value="@sample.css" />
    </stylesheets>
</VBox>
